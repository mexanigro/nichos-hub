rules_version = '2';

// Firebase Storage rules for barbertemplate-madre.firebasestorage.app
//
// 3d-assets/** es lectura publica anonima — los PNGs del Hero son leidos
// por el browser anonimo del visitor del cliente. Las URLs ya incluyen
// download-tokens, pero esta regla cubre el caso de que alguien revoque
// los tokens accidentalmente desde la consola.
//
// Resto del bucket sigue siendo solo-auth.

service firebase.storage {
  match /b/{bucket}/o {

    // Public read for 3D assets (Hero PNGs)
    match /3d-assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default — auth required
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
