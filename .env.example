# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Owner
OWNER_EMAIL=your-email@gmail.com

# Firebase (Admin SDK)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK (public keys — user auth on landing)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# PostgreSQL (Railway - monitor-agent)
DATABASE_URL=

# Anthropic (message classification + content generation + logo SVG)
ANTHROPIC_API_KEY=

# Vercel (deploy + kill switch — pause/unpause client projects)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Vercel template repo (optional, default: mexanigro/Barber-shop-template)
# VERCEL_TEMPLATE_REPO=

# Deploy (secret compartido hub ↔ deploy endpoint interno)
DEPLOY_SECRET=

# Cardcom (pagos)
CARDCOM_TERMINAL=
CARDCOM_API_NAME=

# Google Calendar OAuth (WhatsApp tab)
GOOGLE_REDIRECT_URI=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — protege /api/cron/cardcom-charges
# 1. Generar un UUID aleatorio y ponerlo aqui y en Railway env vars
# 2. En cron-job.org configurar header: Authorization: Bearer <valor>
CRON_SECRET=

# WhatsApp agent (optional — URL del agente whatsapp-agentkit)
# WHATSAPP_AGENT_URL=
AGENT_API_SECRET=

# Firebase multi-database (optional, default: "default")
# FIREBASE_DATABASE_ID=

# VITE_FIREBASE_* — propagated to client Vercel deploys
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Landing page WhatsApp widget (Israeli format, no +)
# Must also be set in Railway env vars for production
NEXT_PUBLIC_WHATSAPP_NUMBER=9720557719141
